# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================

# Para desenvolvimento LOCAL (sem Docker):
# DATABASE_URL=postgresql://user:password@localhost:5432/dt_money

# Para desenvolvimento com Docker Compose (recomendado):
# Nota: quando rodando dentro do docker-compose, o host do DB é 'postgres'
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/dt_money

# Para PRODUÇÃO com Supabase:
# Obtenha a URL em: Settings → Database → Connection String
# Formato: postgresql://[user]:[password]@[host]:[port]/[database]
# DATABASE_URL=postgresql://postgres.xxxxx:password@db.xxxxx.supabase.co:5432/postgres

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================
PORT=3333
NODE_ENV=development

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================
CORS_ORIGIN=http://localhost:3000

# ==============================================================================
# SUPABASE CONFIGURATION (para deploy em produção)
# ==============================================================================
# Obtém em: Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co

# Obtém em: Settings → API → anon public
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Obtém em: Settings → API → service_role secret
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ==============================================================================
# DEPLOYMENT NOTES
# ==============================================================================
# Para Vercel: Adicione todas as variáveis em Settings → Environment Variables
# Para Docker: Crie um arquivo .env.docker com valores específicos
# Para desenvolvimento local: Crie um arquivo .env baseado neste arquivo
